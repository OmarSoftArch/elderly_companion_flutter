rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isCaregiver() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().data.role == 'caregiver';
    }

    function isCaregiverOf(elderlyId) {
      return isCaregiver()
        && exists(/databases/$(database)/documents/users/$(elderlyId))
        && request.auth.uid in get(/databases/$(database)/documents/users/$(elderlyId)).data.caregiverIds;
    }

    function linksSelfAsCaregiver() {
      return isCaregiver()
        && resource.data.role == 'elderly'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['caregiverIds', 'updatedAt'])
        && request.auth.uid in request.resource.data.caregiverIds;
    }

    match /careLinkCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.elderlyId == request.auth.uid
        && request.resource.data.active == true;
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow create: if isSelf(userId);
      allow read: if isSelf(userId) || isCaregiverOf(userId);
      allow update: if isSelf(userId) || isCaregiverOf(userId) || linksSelfAsCaregiver();
      allow delete: if false;

      match /{subcollection}/{documentId} {
        allow read, write: if isSelf(userId) || isCaregiverOf(userId);
      }
    }
  }
}
